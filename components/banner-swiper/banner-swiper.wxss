.banner-sticky-wrap {
  position: sticky;
  top: 0;
  z-index: 99;
  width: 100%;
  background: #F7F8F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.banner-swiper {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-0 { background: linear-gradient(135deg, #2d5016 0%, #3a6b1e 40%, #3a6b1e 100%); }
.banner-1 { background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 40%, #2d5016 100%); }
.banner-2 { background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 40%, #3a6b1e 100%); }
.banner-3 { background: linear-gradient(135deg, #2d5016 0%, #3a6b1e 40%, #4a7a2e 100%); }

.banner-bg-deco {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.banner-circle {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -80rpx;
  right: -60rpx;
  border-width: 2rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -40rpx;
  left: -50rpx;
  border-color: rgba(201, 168, 76,  0.15;
  border-width: 1rpx;
}

.circle-3 {
  width: 120rpx;
  height: 120rpx;
  top: 40rpx;
  right: 60rpx;
  border-color: rgba(255, 255, 255, 0.05);
}

.banner-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.banner-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #c9a84c;
  letter-spacing: 4rpx;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(201, 168, 76, 0.4);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.banner-gold-line {
  width: 48rpx;
  height: 3rpx;
  background: #c9a84c;
  margin: 0 auto;
  border-radius: 2rpx;
}

.banner-dots {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8rpx;
  z-index: 10;
}

.banner-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.banner-dot.active {
  width: 36rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #c9a84c, #d4b85a);
}
