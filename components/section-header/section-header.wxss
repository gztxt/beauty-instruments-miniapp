.section-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D8B7A;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.section-line {
  width: 50rpx;
  height: 3rpx;
  background: linear-gradient(90deg, #3D8B7A, #E8A87C);
  margin: 0 auto;
  border-radius: 2rpx;
}
