.opt-selector { display: block; }
.opt-dim { margin-bottom: 32rpx; }
.opt-dim-head { display: flex; align-items: center; margin-bottom: 16rpx; }
.opt-dim-name { font-size: 28rpx; font-weight: 600; color: #333; }
.opt-required { margin-left: 12rpx; font-size: 20rpx; color: #fff; background: #d0021b; border-radius: 6rpx; padding: 2rpx 10rpx; }
.opt-values { display: flex; flex-wrap: wrap; gap: 16rpx; }
.opt-value { position: relative; display: flex; align-items: center; width: calc(50% - 8rpx); box-sizing: border-box; padding: 20rpx; background: #fff; border: 2rpx solid #e5e5e5; border-radius: 12rpx; }
.opt-value--active { border-color: #2d5016; background: #f3f7ee; }
.opt-value-icon { font-size: 40rpx; margin-right: 16rpx; }
.opt-value-info { display: flex; flex-direction: column; flex: 1; min-width: 0; }
.opt-value-label { font-size: 26rpx; color: #333; }
.opt-value--active .opt-value-label { color: #2d5016; font-weight: 600; }
.opt-value-desc { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.opt-check { position: absolute; top: 8rpx; right: 12rpx; font-size: 24rpx; color: #2d5016; font-weight: 700; }
.opt-summary { margin-top: 24rpx; padding: 24rpx; }
.opt-summary-title { font-size: 26rpx; font-weight: 600; color: #2d5016; margin-bottom: 16rpx; }
.opt-summary-item { display: flex; justify-content: space-between; padding: 8rpx 0; font-size: 24rpx; }
.opt-summary-name { color: #999; }
.opt-summary-label { color: #333; font-weight: 500; }
