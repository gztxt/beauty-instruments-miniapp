<view class="contact-page">

  <!-- ===== 顶部轮播图（复用组件） ===== -->
  <banner-swiper banners="{{banners}}" activeSwiper="{{activeSwiper}}" bind:change="onSwiperChange" />

  <!-- ===== 联系信息 ===== -->
  <view class="container section">
    <view class="section-title">联系方式</view>
    <view class="section-divider"></view>
    <view class="info-card card">
      <view class="info-item">
        <view class="info-icon">
          <image src="/images/icon-company.svg" mode="aspectFit" />
        </view>
        <view class="info-content">
          <text class="info-label">公司名称</text>
          <text class="info-value">{{companyInfo.name}}</text>
        </view>
      </view>
      <view class="info-item">
        <view class="info-icon">
          <image src="/images/icon-address.svg" mode="aspectFit" />
        </view>
        <view class="info-content">
          <text class="info-label">公司地址</text>
          <text class="info-value">{{companyInfo.address}}</text>
        </view>
      </view>
      <view class="info-item">
        <view class="info-icon">
          <image src="/images/icon-phone.svg" mode="aspectFit" />
        </view>
        <view class="info-content">
          <text class="info-label">联系电话</text>
          <text class="info-value">{{companyInfo.phone}}</text>
        </view>
      </view>
      <view class="info-item">
        <view class="info-icon">
          <image src="/images/icon-email.svg" mode="aspectFit" />
        </view>
        <view class="info-content">
          <text class="info-label">电子邮箱</text>
          <text class="info-value">{{companyInfo.email}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="action-btns">
      <button class="action-btn btn-primary" bindtap="makeCall">
        <image src="/images/icon-phone.svg" class="btn-icon" mode="aspectFit" />
        <text>一键拨号</text>
      </button>
      <button class="action-btn btn-primary" bindtap="copyAddress">
        <image src="/images/icon-copy.svg" class="btn-icon" mode="aspectFit" />
        <text>复制地址</text>
      </button>
    </view>
  </view>

  <!-- ===== 在线留言 ===== -->
  <view class="container section">
    <view class="section-title">在线留言</view>
    <view class="section-divider"></view>
    <view class="form-card card">
      <view class="form-group">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          type="text"
          placeholder="请输入您的姓名"
          data-field="name"
          value="{{formData.name}}"
          bindinput="onFieldInput"
        />
      </view>
      <view class="form-group">
        <text class="form-label">电话</text>
        <input
          class="form-input"
          type="number"
          placeholder="请输入您的联系电话"
          data-field="phone"
          value="{{formData.phone}}"
          bindinput="onFieldInput"
        />
      </view>
      <view class="form-group">
        <text class="form-label">留言内容</text>
        <textarea
          class="form-textarea"
          placeholder="请描述您的需求或问题，我们将尽快与您联系"
          data-field="message"
          value="{{formData.message}}"
          bindinput="onFieldInput"
          maxlength="{{500}}"
        />
        <text class="char-count">{{formData.message.length}}/500</text>
      </view>
      <button
        class="submit-btn btn-gold"
        bindtap="submitForm"
        disabled="{{!canSubmit}}"
      >提交留言</button>
    </view>
  </view>

  <!-- ===== 公司位置（地图） ===== -->
  <view class="container section">
    <view class="section-title">公司位置</view>
    <view class="section-divider"></view>
    <map
      class="map-container"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{14}}"
      markers="{{markers}}"
      show-location
    />
  </view>

  <!-- ===== 底部 ===== -->
  <view class="footer">
    <text>© 2025 {{companyInfo.name}} 版权所有</text>
  </view>

</view>
