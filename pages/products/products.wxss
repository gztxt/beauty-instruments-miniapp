/* ===== tab 栏 ===== */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #f0ebe4;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #2d5016;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2d5016;
  border-radius: 2rpx;
}

/* ===== 产品列表 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 0;
}

.product-item {
  width: calc(50% - 10rpx);
  margin-bottom: 10rpx;
}

.product-img {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #e8e0d4, #d4cec4) !important;
  position: relative;
}

/* 可定制标签 */
.customizable-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #2d5016;
  color: #fff;
  font-size: 20rpx;
  line-height: 1;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.product-model {
  font-size: 24rpx;
  color: #c9a84c;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.product-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== 空状态 ===== */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #cccccc;
  font-size: 28rpx;
}
