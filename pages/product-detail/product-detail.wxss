/* ===== 产品详情页样式 ===== */

/* ===== 产品展示区 ===== */
.product-hero {
  width: 100%;
  height: 440rpx;
  background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 50%, #4a7a2e 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-deco-circle {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.hero-deco-circle.c-1 {
  width: 360rpx;
  height: 360rpx;
  top: -120rpx;
  right: -80rpx;
  border-width: 2rpx;
}

.hero-deco-circle.c-2 {
  width: 220rpx;
  height: 220rpx;
  bottom: -60rpx;
  left: -60rpx;
  border-color: rgba(201, 168, 76, 0.12);
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
}

.hero-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  border: 2rpx solid rgba(201, 168, 76, 0.3);
}

.hero-icon-text {
  font-size: 32rpx;
  color: #c9a84c;
  font-weight: 600;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 3rpx;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.hero-model {
  font-size: 26rpx;
  color: rgba(201, 168, 76, 0.8);
  letter-spacing: 2rpx;
}

/* ===== 通用 ===== */
.container {
  padding: 0 24rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d5016;
  text-align: center;
  margin-bottom: 6rpx;
}

.section-divider {
  width: 48rpx;
  height: 3rpx;
  background: linear-gradient(90deg, #2d5016, #c9a84c);
  margin: 0 auto 20rpx;
  border-radius: 2rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* ===== 产品简介 ===== */
.desc-card {
  padding: 30rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
  text-indent: 2em;
}

/* ===== 产品参数 ===== */
.params-card {
  padding: 20rpx 30rpx;
}

.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #f5f5f0;
}

.param-item:last-child {
  border-bottom: none;
}

.param-label {
  font-size: 26rpx;
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}

.param-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

/* ===== 产品特点 ===== */
.features-card {
  padding: 20rpx 0;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f8f5f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(45, 80, 22, 0.06), rgba(201, 168, 76, 0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.feature-icon {
  font-size: 28rpx;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d5016;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* ===== 适用场景 ===== */
.scenes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.scene-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  text-align: center;
  gap: 10rpx;
}

.scene-icon {
  font-size: 40rpx;
}

.scene-text {
  font-size: 24rpx;
  color: #555555;
  font-weight: 500;
}

/* ===== 底部操作栏 ===== */
.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  border-top: 2rpx solid #f0ebe4;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom, 0rpx));
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.footer-inquiry {
  background: linear-gradient(135deg, #c9a84c, #d4b85a);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(201, 168, 76, 0.3);
}

.footer-back {
  background: #ffffff;
  color: #2d5016;
  border: 2rpx solid #2d5016;
}

.footer-btn:active {
  opacity: 0.85;
}

/* ===== 骨架屏 ===== */
.skeleton {
  padding: 0 24rpx;
}

.skeleton-hero {
  width: 100%;
  height: 440rpx;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #e8e0d4, #d4cec4);
  border-radius: 0 0 16rpx 16rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-section {
  margin-bottom: 40rpx;
}

.skeleton-title {
  width: 120rpx;
  height: 30rpx;
  background: #e8e0d4;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-block {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-line {
  height: 24rpx;
  background: #f0ebe4;
  border-radius: 4rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}

.w-80 { width: 80%; }
.w-60 { width: 60%; }
.w-40 { width: 40%; }

@keyframes shimmer {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ===== 未找到页面 ===== */
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  min-height: 60vh;
}

.not-found-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.not-found-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

/* ===== 为固定底部栏留出空间 ===== */
.detail-page {
  padding-bottom: 120rpx;
}
