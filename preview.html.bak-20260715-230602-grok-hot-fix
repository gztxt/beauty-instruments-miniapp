<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="format-detection" content="telephone=no">
<title>采薇美容仪器 - 企业展示（H5 预览）</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --primary: #2d5016;
  --primary-light: #3a6b1e;
  --primary-dark: #1e3a0e;
  --accent: #c9a84c;
  --accent-light: #d4b85a;
  --bg: #F7F8F5;
  --card-bg: #ffffff;
  --text: #2C3E2D;
  --text-secondary: #555555;
  --text-light: #999999;
  --border: #e8e0d4;
  --radius: 12px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
html, body { height: 100%; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: var(--bg);
  color: var(--text);
  max-width: 420px;
  margin: 0 auto;
  min-height: 100vh;
  padding-bottom: calc(64px + var(--safe-bottom));
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
button { font-family: inherit; }
img { max-width: 100%; }

/* ===== 轮播 ===== */
.swiper-wrap {
  position: sticky;
  top: 0;
  z-index: 99;
  overflow: hidden;
  background: var(--bg);
  margin: 0 16px;
  border-radius: 16px;
}
.banner {
  width: 100%;
  height: 200px;
  display: flex;
  transition: transform 0.5s ease;
  will-change: transform;
  touch-action: pan-y;
}
.banner.no-anim { transition: none; }
.banner-slide {
  min-width: 100%;
  height: 200px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.banner-slide.b0 { background: linear-gradient(135deg, #2d5016 0%, #3a6b1e 40%, #3a6b1e 100%); }
.banner-slide.b1 { background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 40%, #2d5016 100%); }
.banner-slide.b2 { background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 40%, #3a6b1e 100%); }
.banner-slide.b3 { background: linear-gradient(135deg, #2d5016 0%, #3a6b1e 40%, #4a7a2e 100%); }
.banner-bg-deco { position: absolute; inset: 0; pointer-events: none; }
.banner-circle {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.08);
}
.banner-circle.c1 { width: 150px; height: 150px; top: -40px; right: -30px; border-width: 2px; }
.banner-circle.c2 { width: 100px; height: 100px; bottom: -20px; left: -25px; border-color: rgba(201,168,76,0.15); }
.banner-circle.c3 { width: 60px; height: 60px; top: 20px; right: 30px; border-color: rgba(255,255,255,0.05); }
.banner-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 20px;
  width: 100%;
}
.banner-tag {
  display: inline-block;
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 2px;
  padding: 3px 12px;
  border: 1px solid rgba(201,168,76,0.4);
  border-radius: 12px;
  margin-bottom: 10px;
}
.banner-title {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1px;
  margin-bottom: 6px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.2);
  line-height: 1.3;
}
.banner-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
  letter-spacing: 1px;
  margin-bottom: 10px;
}
.banner-gold-line {
  width: 28px; height: 2px;
  background: var(--accent);
  margin: 0 auto;
  border-radius: 2px;
}
.swiper-dots {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 6px;
}
.swiper-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(255,255,255,0.35);
  transition: all 0.3s ease;
}
.swiper-dot.active {
  width: 20px; border-radius: 4px;
  background: linear-gradient(90deg, var(--accent), var(--accent-light));
}

/* ===== 通用 ===== */
.container { padding: 0 16px; }
.section { margin-top: 16px; }
.section-title {
  font-size: 18px; font-weight: 700; color: var(--primary);
  margin-bottom: 6px; letter-spacing: 0.5px; text-align: center;
}
.section-divider {
  width: 36px; height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  border-radius: 2px; margin: 0 auto 16px;
}
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.page-pad-bottom { padding-bottom: 8px; }

/* 快速数据 */
.quick-stats {
  display: flex; align-items: center; justify-content: space-around;
  padding: 18px 12px;
  background: var(--card-bg);
  margin: -18px 16px 0;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  position: relative; z-index: 5;
}
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.stat-num { font-size: 20px; font-weight: 700; color: var(--primary); line-height: 1.2; }
.stat-label { font-size: 11px; color: var(--text-light); white-space: nowrap; }
.stat-divider { width: 1px; height: 28px; background: var(--border); }

/* 品牌故事 */
.brand-story { text-align: center; position: relative; overflow: hidden; padding: 28px 20px; }
.brand-story::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 3px; background: linear-gradient(90deg, transparent, var(--accent), transparent);
}
.brand-story::after {
  content: '"'; position: absolute; top: 10px; right: 20px;
  font-size: 60px; color: rgba(201,168,76,0.1);
  font-family: Georgia, serif; line-height: 1;
}
.story-badge { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 12px; }
.story-badge-line { width: 24px; height: 1px; background: var(--accent); }
.story-badge-text { font-size: 11px; color: var(--accent); letter-spacing: 2px; }
.story-title { font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 12px; letter-spacing: 1px; }
.story-desc { font-size: 14px; color: var(--text-light); line-height: 1.8; margin-bottom: 16px; }
.story-highlight { display: flex; flex-direction: column; gap: 6px; align-items: center; }
.hl-item { font-size: 13px; color: var(--text-secondary); display: flex; align-items: center; gap: 4px; }
.hl-icon { color: var(--accent); }

/* 核心优势 */
.advantages-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
.advantage-item { text-align: center; padding: 16px 8px; cursor: default; transition: transform 0.2s; }
.advantage-item:active { transform: scale(0.96); }
.adv-icon-wrap {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(45,80,22,0.08), rgba(201,168,76,0.08));
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 10px;
}
.adv-icon { font-size: 22px; }
.adv-title { font-size: 13px; font-weight: 600; color: var(--primary); margin-bottom: 4px; }
.adv-desc { font-size: 11px; color: var(--text-light); line-height: 1.5; }

/* 热销横向 */
.hot-scroll {
  overflow-x: auto; overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  margin: 0 -16px; padding: 4px 16px 12px;
  scrollbar-width: none;
}
.hot-scroll::-webkit-scrollbar { display: none; }
.hot-track { display: flex; gap: 12px; width: max-content; }
.hot-item {
  width: 148px; flex-shrink: 0; padding: 0; overflow: hidden; cursor: pointer;
  transition: transform 0.2s;
}
.hot-item:active { transform: scale(0.96); }
.hot-img-wrap { position: relative; height: 110px; }
.hot-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: rgba(255,255,255,0.85); font-weight: 600;
}
.img-hot-0 { background: linear-gradient(135deg, #2d5016, #4a7a2e); }
.img-hot-1 { background: linear-gradient(135deg, #c9a84c, #d4b85a); color: #2d5016 !important; }
.img-hot-2 { background: linear-gradient(135deg, #3d6b22, #5a8f3a); }
.img-hot-3 { background: linear-gradient(135deg, #1e3a0e, #2d5016); }
.img-hot-4 { background: linear-gradient(135deg, #4a7a2e, #6a9f4a); }
.img-hot-5 { background: linear-gradient(135deg, #1e3a0e, #2d5016); }
.img-hot-6 { background: linear-gradient(135deg, #3a6b1e, #c9a84c); }
.hot-badge {
  position: absolute; top: 8px; left: 8px;
  background: var(--accent); color: #fff;
  font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; z-index: 2;
}
.customizable-tag {
  position: absolute; top: 8px; right: 8px;
  background: var(--primary); color: #fff;
  font-size: 10px; line-height: 1; padding: 4px 8px; border-radius: 10px; z-index: 2;
}
.hot-info { padding: 10px 12px 12px; }
.hot-name {
  font-size: 13px; font-weight: 600; margin-bottom: 2px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.hot-model { font-size: 11px; color: var(--accent); margin-bottom: 4px; }
.hot-tag {
  display: inline-block; font-size: 10px; color: var(--primary);
  background: rgba(45,80,22,0.08); padding: 1px 8px; border-radius: 8px;
}

/* 主打产品 */
.featured-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.featured-item { overflow: hidden; cursor: pointer; padding: 0; transition: transform 0.2s; }
.featured-item:active { transform: scale(0.96); }
.featured-img {
  position: relative; width: 100%; height: 100px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--primary-light); font-weight: 600;
}
.fi-0 { background: linear-gradient(135deg, #f5f0e8, #e0d5c4); }
.fi-1 { background: linear-gradient(135deg, #e8f0e0, #d4e4c4); }
.fi-2 { background: linear-gradient(135deg, #f0ebe0, #e4d8c0); }
.fi-3 { background: linear-gradient(135deg, #e8ece0, #d0dcc0); }
.fi-4 { background: linear-gradient(135deg, #f5f0e8, #c9a84c33); }
.fi-5 { background: linear-gradient(135deg, #e8f5e0, #d0e8c0); }
.featured-name { font-size: 14px; font-weight: 600; padding: 8px 12px 0; }
.featured-model { font-size: 12px; color: var(--accent); padding: 2px 12px 12px; }

/* CTA */
.cta-section {
  margin: 20px 16px;
  background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 50%, #2d5016 100%);
  border-radius: 16px; padding: 28px 24px; text-align: center;
  position: relative; overflow: hidden;
}
.cta-bg-deco { position: absolute; inset: 0; pointer-events: none; }
.cta-circle {
  position: absolute; width: 180px; height: 180px; border-radius: 50%;
  border: 1px solid rgba(201,168,76,0.12); top: -70px; right: -50px;
}
.cta-content { position: relative; z-index: 2; }
.cta-text { color: #fff; font-size: 17px; font-weight: 700; margin-bottom: 4px; }
.cta-sub { color: rgba(255,255,255,0.6); font-size: 13px; margin-bottom: 16px; }
.btn-gold {
  background: var(--accent); color: #fff; border: none;
  padding: 10px 28px; border-radius: 24px; font-size: 14px;
  font-weight: 600; cursor: pointer; transition: all 0.25s;
  box-shadow: 0 4px 12px rgba(201,168,76,0.35);
}
.btn-gold:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-gold:active { transform: scale(0.97); }

/* 底部 TabBar */
.tabbar {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 420px;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  display: flex; flex-direction: row;
  border-top: 1px solid rgba(0,0,0,0.06);
  z-index: 100;
  padding: 6px 0 var(--safe-bottom);
}
.tabbar-item {
  flex: 1 1 0; min-width: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 3px; padding: 6px 4px;
  font-size: 11px; color: #999; cursor: pointer; transition: color 0.25s;
  position: relative; background: none; border: none;
}
.tabbar-item .tab-icon { display: flex; align-items: center; justify-content: center; transition: transform 0.2s; }
.tabbar-item:active .tab-icon { transform: scale(0.88); }
.tabbar-item.active { color: var(--primary); }
.tabbar-item.active .tab-icon::after {
  content: ''; position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%);
  width: 4px; height: 4px; border-radius: 50%; background: var(--primary);
}
.tab-label { font-weight: 500; }

/* 产品分类 Tab */
.cat-tabs {
  display: flex; background: #fff;
  position: sticky; top: 0; z-index: 50;
  margin: 0 16px; border-radius: 0 0 12px 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  border-bottom: 1px solid var(--border);
}
.cat-tab {
  flex: 1; padding: 14px 4px; font-size: 13px; color: var(--text-light);
  text-align: center; border-bottom: 2px solid transparent;
  cursor: pointer; transition: all 0.25s; white-space: nowrap;
  background: none; border-top: none; border-left: none; border-right: none;
  font-family: inherit;
}
.cat-tab.active {
  color: var(--primary); border-bottom-color: var(--accent); font-weight: 600;
}

/* 产品列表 */
.product-grid { display: grid; grid-template-columns: 1fr; gap: 12px; padding-top: 12px; }
.product-item {
  display: flex; gap: 12px; padding: 12px; cursor: pointer; transition: filter 0.2s;
}
.product-item:active { filter: brightness(0.97); }
.product-img {
  position: relative; width: 96px; height: 96px; flex-shrink: 0;
  background: linear-gradient(135deg, #f5f0e8, #e8e0d4);
  display: flex; align-items: center; justify-content: center;
  border-radius: 8px; font-size: 12px; color: var(--primary-light); font-weight: 600;
  overflow: hidden;
}
.product-img .customizable-tag { top: 6px; right: 6px; font-size: 9px; padding: 3px 6px; }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
.product-name { font-size: 15px; font-weight: 600; margin-bottom: 2px; }
.product-model { font-size: 12px; color: var(--accent); margin-bottom: 4px; }
.product-desc {
  font-size: 12px; color: var(--text-light); line-height: 1.5;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.empty-tip { text-align: center; padding: 40px 16px; color: var(--text-light); font-size: 14px; }

/* 关于页 */
.page-banner {
  height: 160px; margin: 0 16px; border-radius: 16px; overflow: hidden;
  background: linear-gradient(135deg, #1e3a0e, var(--primary));
  position: relative; display: flex; align-items: center; justify-content: center;
}
.desc-text { font-size: 14px; color: var(--text-light); line-height: 1.8; margin-bottom: 10px; }
.desc-text:last-child { margin-bottom: 0; }

/* 使命愿景 */
.mvv-grid { display: flex; flex-direction: column; gap: 12px; }
.mvv-item { padding: 18px 16px; }
.mvv-label {
  display: inline-block; font-size: 11px; color: var(--accent);
  letter-spacing: 2px; margin-bottom: 6px; font-weight: 600;
}
.mvv-title { font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 8px; }
.mvv-desc { font-size: 13px; color: var(--text-light); line-height: 1.7; }
.mvv-line { margin-bottom: 4px; }
.mvv-highlight { color: var(--primary); font-weight: 600; }

/* 时间线 */
.timeline { position: relative; padding-left: 20px; }
.timeline::before {
  content: ''; position: absolute; left: 8px; top: 4px; bottom: 4px;
  width: 2px; background: var(--border);
}
.timeline-item { position: relative; padding-bottom: 18px; }
.timeline-item:last-child { padding-bottom: 0; }
.timeline-dot {
  position: absolute; left: -15px; top: 4px;
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--accent); border: 2px solid var(--bg);
}
.timeline-dot.first { width: 14px; height: 14px; left: -16px; top: 2px; background: var(--primary); }
.tl-year { font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
.tl-desc { font-size: 13px; color: var(--text-light); line-height: 1.6; }

/* 认证 */
.certs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.cert-item { text-align: center; padding: 16px 8px; }
.cert-img {
  width: 56px; height: 56px; border-radius: 50%; margin: 0 auto 8px;
  background: linear-gradient(135deg, #f5f0e8, rgba(201,168,76,0.2));
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700; color: var(--primary);
}
.cert-name { font-size: 12px; color: var(--text-light); }

/* 联系我们 */
.contact-card { padding: 4px 16px; }
.contact-row {
  display: flex; gap: 12px; padding: 12px 0;
  border-bottom: 1px solid #f0f0f0; align-items: flex-start;
}
.contact-row:last-child { border-bottom: none; }
.contact-label { font-size: 13px; color: var(--text-light); width: 40px; flex-shrink: 0; padding-top: 1px; }
.contact-value { font-size: 14px; color: var(--text); flex: 1; word-break: break-all; line-height: 1.5; }
.contact-actions { display: flex; gap: 10px; margin-top: 12px; }
.contact-action-btn {
  flex: 1; padding: 12px 8px; border: 1px solid var(--primary); border-radius: 8px;
  background: #fff; color: var(--primary); font-size: 12px; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  transition: background 0.2s;
}
.contact-action-btn:hover { background: #f5f0e8; }
.contact-action-btn:active { background: #ebe4d8; }
.action-ico { font-size: 16px; }

/* 询价配置卡 */
.inquiry-card { margin-bottom: 12px; border: 1px solid rgba(201,168,76,0.35); background: #fffdf8; }
.inquiry-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.inquiry-title { font-size: 14px; font-weight: 700; color: var(--primary); }
.inquiry-clear { font-size: 12px; color: var(--text-light); cursor: pointer; background: none; border: none; }
.inquiry-product { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.inquiry-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px dashed #f0e8d8; }
.inquiry-dim { color: var(--text-light); }
.inquiry-val { color: var(--text); font-weight: 500; }
.inquiry-copy-btn {
  width: 100%; margin-top: 12px; padding: 10px; border: none; border-radius: 8px;
  background: var(--primary); color: #fff; font-size: 14px; cursor: pointer; font-weight: 600;
}

/* 产品详情 */
.detail-page { min-height: 60vh; }
.detail-hero {
  height: 200px; margin: 0 16px; border-radius: 16px; overflow: hidden;
  background: linear-gradient(135deg, #1e3a0e, #2d5016 50%, #3a6b1e);
  position: relative; display: flex; align-items: center; justify-content: center;
}
.detail-hero-deco { position: absolute; inset: 0; pointer-events: none; }
.detail-hero-deco .c1 {
  position: absolute; width: 140px; height: 140px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.1); top: -40px; right: -30px;
}
.detail-hero-deco .c2 {
  position: absolute; width: 90px; height: 90px; border-radius: 50%;
  border: 1px solid rgba(201,168,76,0.15); bottom: -20px; left: -20px;
}
.detail-hero-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 0 16px; }
.detail-hero-icon {
  width: 72px; height: 72px; border-radius: 50%; margin: 0 auto 12px;
  background: rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.9);
}
.detail-hero-name { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.detail-hero-model { font-size: 13px; color: var(--accent); letter-spacing: 1px; }

.params-card .param-item {
  display: flex; justify-content: space-between; gap: 12px;
  padding: 10px 0; border-bottom: 1px solid #f5f5f5; font-size: 13px;
}
.params-card .param-item:last-child { border-bottom: none; }
.param-label { color: var(--text-light); flex-shrink: 0; }
.param-value { color: var(--text); font-weight: 500; text-align: right; }

.feature-item {
  display: flex; gap: 12px; padding: 12px 0;
  border-bottom: 1px solid #f5f5f5; align-items: flex-start;
}
.feature-item:last-child { border-bottom: none; }
.feature-icon-wrap {
  width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
  background: linear-gradient(135deg, rgba(45,80,22,0.08), rgba(201,168,76,0.1));
  display: flex; align-items: center; justify-content: center; font-size: 18px;
}
.feature-title { font-size: 14px; font-weight: 600; color: var(--primary); margin-bottom: 2px; }
.feature-desc { font-size: 12px; color: var(--text-light); line-height: 1.5; }

.scenes-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.scene-item {
  display: flex; align-items: center; gap: 8px; padding: 12px;
  font-size: 13px;
}
.scene-icon { font-size: 18px; }

/* 选配 */
.opt-group { margin-bottom: 16px; }
.opt-group:last-child { margin-bottom: 0; }
.opt-group-title {
  font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}
.opt-req {
  font-size: 10px; color: #c0392b; background: rgba(192,57,43,0.08);
  padding: 1px 6px; border-radius: 4px; font-weight: 500;
}
.opt-values { display: flex; flex-wrap: wrap; gap: 8px; }
.opt-chip {
  border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px;
  cursor: pointer; background: #fff; min-width: 96px; transition: all 0.2s;
  text-align: left; font-family: inherit;
}
.opt-chip:hover { border-color: var(--primary-light); }
.opt-chip.active {
  border-color: var(--primary); background: rgba(45,80,22,0.06);
  box-shadow: 0 0 0 1px var(--primary);
}
.opt-chip-label { font-size: 13px; font-weight: 600; color: var(--text); display: block; }
.opt-chip-desc { font-size: 11px; color: var(--text-light); margin-top: 2px; display: block; }

.detail-bar {
  position: sticky; bottom: calc(56px + var(--safe-bottom));
  display: flex; gap: 10px; padding: 12px 16px;
  background: rgba(255,255,255,0.96); backdrop-filter: blur(8px);
  border-top: 1px solid rgba(0,0,0,0.06); z-index: 80;
  margin: 16px -0 0;
}
.detail-bar .btn-outline {
  flex: 1; padding: 12px; border: 1px solid var(--primary); border-radius: 24px;
  background: #fff; color: var(--primary); font-size: 14px; font-weight: 600; cursor: pointer;
}
.detail-bar .btn-primary {
  flex: 1.4; padding: 12px; border: none; border-radius: 24px;
  background: var(--primary); color: #fff; font-size: 14px; font-weight: 600; cursor: pointer;
}
.detail-bar button:active { opacity: 0.9; }

.back-bar {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 16px 8px; font-size: 14px; color: var(--primary);
  cursor: pointer; font-weight: 600; background: none; border: none; width: 100%; text-align: left;
}
.back-bar:active { opacity: 0.7; }

/* 页脚 */
.footer {
  text-align: center; padding: 24px 16px 12px;
  font-size: 12px; color: #999;
}

/* Toast */
.toast {
  position: fixed; top: 80px; left: 50%; transform: translateX(-50%) translateY(-8px);
  background: rgba(0,0,0,0.78); color: #fff; padding: 10px 20px;
  border-radius: 8px; font-size: 14px; z-index: 300;
  opacity: 0; pointer-events: none; transition: opacity 0.25s, transform 0.25s;
  max-width: 80%; text-align: center;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* 无障碍 */
.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); border: 0;
}
</style>
