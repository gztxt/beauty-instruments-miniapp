// ================= 状态与逻辑 =================
let currentPage = 0;       // 0 home / 1 products / 2 about
let productTab = 0;
let detailId = null;       // null = 不在详情
let detailFromTab = 1;
let optionState = {};
let swiperTimer = null;
let swiperIdx = 0;
let touchStartX = 0;
let touchDeltaX = 0;
let activeBannerId = null;
let activeDotsId = null;
let activeSlideCount = 0;

function switchTab(idx) {
  currentPage = idx;
  detailId = null;
  render();
  window.scrollTo(0, 0);
}

function switchProductTab(idx) {
  productTab = idx;
  detailId = null;
  render();
}

function openDetail(id) {
  detailId = id;
  detailFromTab = currentPage;
  render();
  window.scrollTo({ top: 0, behavior: 'auto' });
}

function closeDetail() {
  detailId = null;
  render();
  window.scrollTo({ top: 0, behavior: 'auto' });
}

function selectOption(pid, key, vid) {
  if (!optionState[pid]) optionState[pid] = {};
  optionState[pid][key] = vid;
  render();
}

function consultProduct(pid) {
  const p = findProduct(pid);
  if (!p) return;
  const selected = optionState[pid] || {};
  const summary = (p.options || []).map(o => {
    const v = (o.values || []).find(x => x.id === selected[o.key]);
    return v ? { key: o.key, name: o.name, label: v.label } : null;
  }).filter(Boolean);

  inquiryConfig = {
    productId: p.id,
    productName: p.name + '（' + p.model + '）',
    summary: summary,
    updatedAt: Date.now()
  };
  try { localStorage.setItem('inquiryConfig', JSON.stringify(inquiryConfig)); } catch (e) {}

  currentPage = 2;
  detailId = null;
  render();
  showToast('配置已保存，可复制发给客服');
  setTimeout(() => {
    const el = document.getElementById('contact-section');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 80);
}

function clearInquiry() {
  inquiryConfig = null;
  try { localStorage.removeItem('inquiryConfig'); } catch (e) {}
  render();
  showToast('已清除咨询配置');
}

function copyInquiry() {
  if (!inquiryConfig) return;
  const lines = [
    '【采薇选配咨询】',
    '产品：' + inquiryConfig.productName,
    ...inquiryConfig.summary.map(s => s.name + '：' + s.label),
    '—— 来自 H5 预览页'
  ];
  copyText(lines.join('\n'), '配置已复制');
}

function makeCall() {
  const phone = (companyInfo.phone || '').replace(/-/g, '').replace(/X/gi, '');
  if (!phone || !/^\d{7,}$/.test(phone)) {
    showToast('演示号码，请替换为真实电话');
    return;
  }
  window.location.href = 'tel:' + phone;
}

function copyText(text, okMsg) {
  const t = String(text || '').trim();
  if (!t) { showToast('内容为空'); return; }
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(t).then(() => showToast(okMsg || '已复制'))
      .catch(() => fallbackCopy(t, okMsg));
  } else {
    fallbackCopy(t, okMsg);
  }
}

function fallbackCopy(text, okMsg) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.cssText = 'position:fixed;left:-9999px;top:0';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    showToast(okMsg || '已复制');
  } catch (e) {
    showToast('复制失败，请手动选择');
  }
  document.body.removeChild(ta);
}

function render() {
  stopSwiper();
  const app = document.getElementById('app');
  if (detailId != null) {
    app.innerHTML = renderDetail();
    return;
  }
  const pages = [renderHome, renderProducts, renderAbout];
  app.innerHTML = pages[currentPage]();

  const map = [
    { banner: 'banner-home', dots: 'dots-home', count: 4 },
    { banner: 'banner-products', dots: 'dots-products', count: 3 },
    null
  ];
  const conf = map[currentPage];
  if (conf) startSwiper(conf.banner, conf.dots, conf.count);
}

function stopSwiper() {
  if (swiperTimer) { clearInterval(swiperTimer); swiperTimer = null; }
}

function startSwiper(bannerId, dotsId, slideCount) {
  stopSwiper();
  const banner = document.getElementById(bannerId);
  if (!banner || slideCount < 2) return;

  activeBannerId = bannerId;
  activeDotsId = dotsId;
  activeSlideCount = slideCount;
  swiperIdx = 0;
  applySwiper(0);

  // 指示点点击
  const dots = document.getElementById(dotsId);
  if (dots) {
    dots.querySelectorAll('.swiper-dot').forEach(d => {
      d.style.cursor = 'pointer';
      d.addEventListener('click', () => {
        applySwiper(Number(d.dataset.idx) || 0);
        restartAuto();
      });
    });
  }

  // 触摸滑动
  banner.addEventListener('touchstart', onTouchStart, { passive: true });
  banner.addEventListener('touchmove', onTouchMove, { passive: true });
  banner.addEventListener('touchend', onTouchEnd, { passive: true });

  restartAuto();
}

function restartAuto() {
  if (swiperTimer) clearInterval(swiperTimer);
  swiperTimer = setInterval(() => {
    applySwiper((swiperIdx + 1) % activeSlideCount);
  }, 4000);
}

function applySwiper(idx) {
  swiperIdx = idx;
  const banner = document.getElementById(activeBannerId);
  if (!banner) return;
  banner.style.transform = 'translateX(-' + (swiperIdx * 100) + '%)';
  const dotsRoot = document.getElementById(activeDotsId);
  if (dotsRoot) {
    dotsRoot.querySelectorAll('.swiper-dot').forEach((d, i) => {
      d.classList.toggle('active', i === swiperIdx);
    });
  }
}

function onTouchStart(e) {
  if (!e.touches || !e.touches[0]) return;
  touchStartX = e.touches[0].clientX;
  touchDeltaX = 0;
  const banner = document.getElementById(activeBannerId);
  if (banner) banner.classList.add('no-anim');
  if (swiperTimer) clearInterval(swiperTimer);
}

function onTouchMove(e) {
  if (!e.touches || !e.touches[0]) return;
  touchDeltaX = e.touches[0].clientX - touchStartX;
  const banner = document.getElementById(activeBannerId);
  if (!banner) return;
  const base = -swiperIdx * 100;
  const pct = (touchDeltaX / banner.clientWidth) * 100;
  banner.style.transform = 'translateX(' + (base + pct) + '%)';
}

function onTouchEnd() {
  const banner = document.getElementById(activeBannerId);
  if (banner) banner.classList.remove('no-anim');
  const threshold = 40;
  if (touchDeltaX < -threshold) {
    applySwiper(Math.min(activeSlideCount - 1, swiperIdx + 1));
  } else if (touchDeltaX > threshold) {
    applySwiper(Math.max(0, swiperIdx - 1));
  } else {
    applySwiper(swiperIdx);
  }
  touchDeltaX = 0;
  restartAuto();
}

function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(showToast._t);
  showToast._t = setTimeout(() => el.classList.remove('show'), 2200);
}

// 启动
render();
</script>
</body>
</html>
