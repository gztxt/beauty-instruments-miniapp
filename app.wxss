/* ===== 全局样式 ===== */

page {
  background-color: #F7F8F5;
  color: #2C3E2D;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ===== 品牌色 ===== */
.brand-bg { background-color: #2d5016; }
.brand-text { color: #2d5016; }
.gold-text { color: #c9a84c; }
.gold-bg { background-color: #c9a84c; }

/* ===== 卡片通用样式 ===== */
.card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* ===== 占位图样式 ===== */
.placeholder-img {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E0E8E0, #e8e0d4);
  color: #999999;
  font-size: 24rpx;
  overflow: hidden;
}
.placeholder-img text {
  text-align: center;
  line-height: 1.5;
}

/* ===== 页面标题 ===== */
.page-title {
  text-align: center;
  padding: 40rpx 30rpx 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #2d5016;
}
.page-subtitle {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

/* ===== 分隔线 ===== */
.section-divider {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #2d5016, #c9a84c);
  margin: 0 auto 30rpx;
  border-radius: 2rpx;
}

/* ===== 按钮样式 ===== */
.btn-primary {
  background: linear-gradient(135deg, #2d5016, #3a6b1e);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(45, 80, 22,  0.25;
}
.btn-primary::after { border: none; }

.btn-gold {
  background: linear-gradient(135deg, #c9a84c, #d4b85a);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(201, 168, 76,  0.3;
}
.btn-gold::after { border: none; }

/* ===== 容器 ===== */
.container { padding: 0 30rpx; }
.section { margin-bottom: 40rpx; }

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d5016;
  margin-bottom: 24rpx;
  text-align: center;
}

/* ===== 共享 Banner 装饰元素 ===== */
/* 供 about/products/contact 页面共用 */

.banner-bg-deco {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.banner-circle {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.banner-circle.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -80rpx;
  right: -60rpx;
  border-width: 2rpx;
}

.banner-circle.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -40rpx;
  left: -50rpx;
  border-color: rgba(201, 168, 76,  0.15;
}

.banner-circle.circle-3 {
  width: 120rpx;
  height: 120rpx;
  top: 40rpx;
  right: 60rpx;
  border-color: rgba(255, 255, 255, 0.05);
}

.banner-content-wrap {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.banner-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #c9a84c;
  letter-spacing: 4rpx;
  padding: 6rpx 24rpx;
  border: 1rpx solid rgba(201, 168, 76,  0.4;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.banner-gold-line {
  width: 48rpx;
  height: 3rpx;
  background: #c9a84c;
  margin: 0 auto;
  border-radius: 2rpx;
}

/* 统一的页面 Banner */
.page-banner,
.banner-default {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #1e3a0e 0%, #2d5016 50%, #2d5016 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
